[Unit]
Description=Classroom Control Backend
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=user
WorkingDirectory=/home/user/dev_projects/tutor-assistant-app/backend
ExecStart=/home/user/dev_projects/tutor-assistant-app/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8082
Restart=always
RestartSec=5
EnvironmentFile=/etc/classroom-control/secrets

[Install]
WantedBy=multi-user.target
